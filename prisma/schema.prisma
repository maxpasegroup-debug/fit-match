  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cart        Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  reminders   AbandonedCartReminder[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, status])
  @@index([detectedAt])
}

model AbandonedCartReminder {
  id              String        @id @default(cuid())
  abandonedCartId String
  sequence        Int
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  abandonedCart   AbandonedCart @relation(fields: [abandonedCartId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([abandonedCartId, sequence])
  @@index([sentAt])
}

model CampaignMetric {
  id          String             @id @default(cuid())
  metricType  CampaignMetricType
  campaignId  String?
  promotionId String?
  value       Decimal            @default(0) @db.Decimal(12, 4)
  metadata    Json?
  recordedAt  DateTime           @default(now())

  @@index([metricType, recordedAt])
  @@index([campaignId])
  @@index([promotionId])
}
