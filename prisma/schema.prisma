  orderDraftId        String               @unique
  paymentId           String               @unique
  status              OrderStatus          @default(PAID)
  subtotal            Decimal              @db.Decimal(10, 2)
  discount            Decimal              @default(0) @db.Decimal(10, 2)
  couponDiscount      Decimal              @default(0) @db.Decimal(10, 2)
  deliveryCharge      Decimal              @default(0) @db.Decimal(10, 2)
  tax                 Decimal              @default(0) @db.Decimal(10, 2)
  grandTotal          Decimal              @db.Decimal(10, 2)
  currency            String               @default("INR")
  deliveryAddressSnapshot Json
  billingAddressSnapshot  Json?
  measurementSnapshot Json?
  giftNoteSnapshot    Json?
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  checkoutSession     CheckoutSession      @relation(fields: [checkoutSessionId], references: [id], onDelete: Restrict)
  orderDraft          OrderDraft           @relation(fields: [orderDraftId], references: [id], onDelete: Restrict)
