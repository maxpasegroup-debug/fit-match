  couponId                 String?
  status                   CheckoutSessionStatus @default(ACTIVE)
  subtotal                 Decimal               @db.Decimal(10, 2)
  discount                 Decimal               @default(0) @db.Decimal(10, 2)
  couponDiscount           Decimal               @default(0) @db.Decimal(10, 2)
  deliveryCharge           Decimal               @default(0) @db.Decimal(10, 2)
  tax                      Decimal               @default(0) @db.Decimal(10, 2)
  grandTotal               Decimal               @db.Decimal(10, 2)
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cart                     Cart                  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  deliveryAddress           Address?              @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  billingAddress            BillingAddress?       @relation(fields: [billingAddressId], references: [id], onDelete: SetNull)
