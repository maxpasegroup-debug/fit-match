  id                  String         @id @default(cuid())
  cartId              String
  productId           String
  productVariantId    String?
  measurementProfileId String?
  quantity            Int            @default(1)
  status              CartItemStatus @default(ACTIVE)
  unitPrice           Decimal        @db.Decimal(10, 2)
  cart                Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product             Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant      ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  measurementProfile  MeasurementProfile? @relation(fields: [measurementProfileId], references: [id], onDelete: SetNull)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

