generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  FEMALE
  MALE
  NON_BINARY
  PREFER_NOT_TO_SAY
  OTHER
}

enum HeightUnit {
  CM
  FT_IN
}

enum WeightUnit {
  KG
  LB
}

enum BodyType {
  PEAR
  APPLE
  HOURGLASS
  RECTANGLE
  INVERTED_TRIANGLE
  OTHER
}

enum SkinTone {
  VERY_FAIR
  FAIR
  MEDIUM
  WHEATISH
  BROWN
  DARK
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  INITIAL_STOCK
  STOCK_ADDED
  STOCK_REMOVED
  MANUAL_ADJUSTMENT
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum CartItemStatus {
  ACTIVE
  SAVED_FOR_LATER
}

enum CheckoutSessionStatus {
  ACTIVE
  PAYMENT_PENDING
  COMPLETED
  ABANDONED
  FAILED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentAttemptStatus {
  CREATED
  AUTHORIZED
  PAID
  FAILED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_FAILED
  PAID
  CONFIRMED
  ASSIGNED_TO_TAILOR
  STITCHING_STARTED
  QUALITY_CHECK
  PACKING
  READY_TO_SHIP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUND_INITIATED
  REFUNDED
  RETURNED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum TailoringStageName {
  CUTTING
  STITCHING
  FINISHING
  IRONING
  COMPLETED
}

enum ShipmentStatus {
  PENDING
  PACKED
  LABEL_GENERATED
  DISPATCHED
  IN_TRANSIT
  REACHED_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURNED_TO_ORIGIN
  LOST
}

enum CourierProviderStatus {
  ACTIVE
  INACTIVE
}

enum ShippingServiceLevel {
  STANDARD
  EXPRESS
}

enum MediaFolderKind {
  PRODUCTS
  COLLECTIONS
  CATEGORIES
  BANNERS
  PROFILES
  MARKETING
  LOOKBOOKS
  TEMPORARY
}

enum MediaUsageType {
  PRODUCT_PRIMARY
  PRODUCT_GALLERY
  CATEGORY_COVER
  COLLECTION_COVER
  BANNER_DESKTOP
  BANNER_TABLET
  BANNER_MOBILE
  PROFILE_AVATAR
  MARKETING_ASSET
}

enum MediaAuditAction {
  UPLOAD
  DELETE
  RENAME
  MOVE
  REPLACE
}

enum PreferredFit {
  SLIM
  REGULAR
  RELAXED
  OVERSIZED
  CUSTOM
}

enum FitRuleType {
  SIZE
  COLOR
  FABRIC
  STYLE
  OCCASION
  PRODUCT
}

enum FitFeedbackType {
  TOO_TIGHT
  PERFECT_FIT
  TOO_LOOSE
  TOO_LONG
  TOO_SHORT
  LOVED_IT
}

enum AIFeature {
  STYLIST
  MEASUREMENT
  VIRTUAL_TRY_ON
  STYLE_SUGGESTION
  WEATHER
}

enum AISessionStatus {
  DRAFT
  PROCESSING
  COMPLETED
  ACCEPTED
  FAILED
  CANCELLED
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum VirtualTryOnStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum StyleSuggestionType {
  DAILY
  WEEKLY
  FESTIVAL
  WEDDING
  OFFICE
  TRAVEL
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
  REPORTED
}

enum ReviewVoteType {
  HELPFUL
  NOT_HELPFUL
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTIONED
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

enum LoyaltySource {
  PURCHASE
  REFERRAL
  REVIEW
  BIRTHDAY
  MILESTONE
  ADMIN
  PROMOTION
}

enum ReferralStatus {
  INVITED
  JOINED
  REWARDED
  EXPIRED
  CANCELLED
}

enum PromotionType {
  FLASH_SALE
  FESTIVAL_SALE
  CATEGORY_DISCOUNT
  COLLECTION_DISCOUNT
  BOGO
  FREE_SHIPPING
  MEMBER_EXCLUSIVE
}

enum PromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum NotificationType {
  ORDER
  OFFER
  REFERRAL
  REWARD
  SYSTEM
  REVIEW_REMINDER
  WISHLIST_REMINDER
  BACK_IN_STOCK
  PRICE_DROP
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum AnnouncementPlacement {
  HOMEPAGE
  IN_APP
  FESTIVAL
}

enum CampaignMetricType {
  REVIEW_CONVERSION
  REFERRAL_CONVERSION
  REWARD_REDEMPTION
  NOTIFICATION_OPEN
  CAMPAIGN_PERFORMANCE
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  avatar        String?
  avatarMediaAssetId String?
  sessions      Session[]
  profile       UserProfile?
  addresses     Address[]
  measurements  MeasurementProfile[]
  wishlist      Wishlist[]
  recentlyViewed RecentlyViewed[]
  reviews       ProductReview[]
  inventoryMovements InventoryMovement[] @relation("InventoryMovementAdmin")
  auditLogs     AuditLog[] @relation("AuditLogAdmin")
  cart          Cart?
  couponsUsed   CouponUsage[]
  checkoutSessions CheckoutSession[]
  payments      Payment[]
  orderDrafts   OrderDraft[]
  orders        Order[]
  cancellationRequests CancellationRequest[]
  returnRequests ReturnRequest[]
  refundRequests RefundRequest[]
  orderStatusChanges OrderStatusHistory[] @relation("OrderStatusChangedBy")
  orderNotes OrderNote[] @relation("OrderNoteAdmin")
  tailoringAssignments TailoringJob[] @relation("TailoringAssignedBy")
  qualityChecks QualityCheck[] @relation("QualityCheckInspector")
  deliveryAttempts DeliveryAttempt[] @relation("DeliveryAttemptAdmin")
  warehouseActions WarehouseInventory[] @relation("WarehouseInventoryAdmin")
  dispatchBatches DispatchBatch[] @relation("DispatchBatchAdmin")
  avatarMediaAsset MediaAsset? @relation("UserAvatarMedia", fields: [avatarMediaAssetId], references: [id], onDelete: SetNull)
  uploadedMediaAssets MediaAsset[] @relation("MediaUploadedBy")
  mediaAudits MediaAudit[] @relation("MediaAuditActor")
  fitProfiles FitProfile[]
  fitRecommendations FitRecommendation[]
  recommendationFeedback RecommendationFeedback[]
  aiMeasurementSessions AIMeasurementSession[]
  aiRecommendations AIRecommendation[]
  aiConversations AIConversation[]
  virtualTryOnSessions VirtualTryOnSession[]
  styleSuggestions StyleSuggestion[]
  weatherProfiles WeatherProfile[]
  aiUsageLogs AIUsageLog[]
  engagementReviews Review[]
  reviewVotes ReviewVote[]
  reviewReports ReviewReport[]
  reviewReplies ReviewReply[] @relation("ReviewReplyAdmin")
  loyaltyAccount LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[] @relation("LoyaltyTransactionUser")
  loyaltyAdjustments LoyaltyTransaction[] @relation("LoyaltyTransactionAdmin")
  referralProgram ReferralProgram?
  referralsSent Referral[] @relation("ReferralSender")
  referralsReceived Referral[] @relation("ReferralReceiver")
  notifications Notification[]
  notificationPreference NotificationPreference?
  abandonedCarts AbandonedCart[]
  wishlistReminders WishlistReminder[]
  recentlyViewedReminders RecentlyViewedReminder[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
  @@index([createdAt])
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  image         String?
  imageMediaAssetId String?
  sortOrder     Int           @default(0)
  published     Boolean       @default(true)
  subCategories SubCategory[]
  products      Product[]
  auditLogs     AuditLog[]
  sizeCharts    SizeChart[]
  imageMediaAsset MediaAsset? @relation("CategoryImageMedia", fields: [imageMediaAssetId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([published, sortOrder])
}

model SubCategory {
  id          String    @id @default(cuid())
  categoryId  String
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  published   Boolean   @default(true)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products    Product[]
  auditLogs   AuditLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
  @@index([published, sortOrder])
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  imageMediaAssetId String?
  featured    Boolean   @default(false)
  published   Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]
  banners     FeaturedBanner[]
  auditLogs   AuditLog[]
  imageMediaAsset MediaAsset? @relation("CollectionImageMedia", fields: [imageMediaAssetId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([featured, published])
  @@index([published, sortOrder])
}

model Product {
  id                       String            @id @default(cuid())
  categoryId               String
  subCategoryId            String?
  collectionId             String?
  supplierId               String?
  seasonId                 String?
  occasionId               String?
  name                     String
  slug                     String            @unique
  sku                      String            @unique
  shortDescription         String
  longDescription          String?
  brand                    String            @default("Sign Silks")
  price                    Decimal           @db.Decimal(10, 2)
  offerPrice               Decimal?          @db.Decimal(10, 2)
  discountPercent          Int               @default(0)
  featured                 Boolean           @default(false)
  trending                 Boolean           @default(false)
  newArrival               Boolean           @default(false)
  bestSeller               Boolean           @default(false)
  published                Boolean           @default(false)
  available                Boolean           @default(true)
  status                   ProductStatus     @default(DRAFT)
  popularity               Int               @default(0)
  sortOrder                Int               @default(0)
  estimatedStitchingTime   String?
  estimatedDelivery        String?
  archivedAt               DateTime?
  deletedAt                DateTime?
  category                 Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory              SubCategory?      @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  collection               Collection?       @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  supplier                 Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  season                   Season?           @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  occasion                 Occasion?         @relation(fields: [occasionId], references: [id], onDelete: SetNull)
  images                   ProductImage[]
  variants                 ProductVariant[]
  fabrics                  ProductFabric[]
  colors                   ProductColor[]
  sizes                    ProductSize[]
  tags                     ProductTag[]
  materials                ProductMaterial[]
  attributes               ProductAttribute[]
  seo                      ProductSEO?
  inventory                Inventory?
  wishlist                 Wishlist[]
  recentlyViewed           RecentlyViewed[]
  reviews                  ProductReview[]
  cartItems                CartItem[]
  orderItems               OrderItem[]
  warehouseInventory       WarehouseInventory[]
  fitRecommendations       FitRecommendation[]
  fitScores                FitScore[]
  virtualTryOnSessions     VirtualTryOnSession[]
  engagementReviews        Review[]
  wishlistReminders        WishlistReminder[]
  recentlyViewedReminders  RecentlyViewedReminder[]
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([collectionId])
  @@index([supplierId])
  @@index([seasonId])
  @@index([occasionId])
  @@index([published, available])
  @@index([status])
  @@index([featured, trending, newArrival, bestSeller])
  @@index([price])
  @@index([createdAt])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  sku         String   @unique
  colorName   String?
  sizeName    String?
  fabricName  String?
  price       Decimal? @db.Decimal(10, 2)
  offerPrice  Decimal? @db.Decimal(10, 2)
  available   Boolean  @default(true)
  stockLabel  String?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  fitRecommendations FitRecommendation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([available])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  mediaAssetId String?
  url         String
  alt         String?
  caption     String?
  isPrimary   Boolean  @default(false)
  displayOrder Int     @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset? @relation("ProductImageMedia", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([productId, displayOrder])
  @@index([productId, isPrimary])
  @@index([mediaAssetId])
}

model ProductSEO {
  id          String   @id @default(cuid())
  productId   String   @unique
  title       String?
  description String?
  keywords    String?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductMaterial {
  id        String   @id @default(cuid())
  productId String
  name      String
  details   String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([name])
}

model ProductAttribute {
  id        String           @id @default(cuid())
  productId String
  name      String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    AttributeValue[]

  @@index([productId])
  @@index([name])
}

model AttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  value       String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([attributeId])
}

model ProductFabric {
  id               String   @id @default(cuid())
  productId         String
  name              String
  description       String?
  careInstructions  String?
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([name])
}

model ProductColor {
  id          String   @id @default(cuid())
  productId   String
  name        String
  hexCode     String
  preview     String?
  available   Boolean  @default(true)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([name])
}

model ProductSize {
  id          String   @id @default(cuid())
  productId   String
  name        String
  available   Boolean  @default(true)
  sortOrder   Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@index([productId, sortOrder])
}

model ProductTag {
  id        String   @id @default(cuid())
  productId String
  name      String
  slug      String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, slug])
  @@index([slug])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, viewedAt])
}

model FeaturedBanner {
  id           String      @id @default(cuid())
  title        String
  subtitle     String?
  image        String?
  desktopMediaAssetId String?
  tabletMediaAssetId String?
  mobileMediaAssetId String?
  href         String?
  collectionId String?
  published    Boolean     @default(true)
  activeAt      DateTime?
  expiresAt     DateTime?
  sortOrder    Int         @default(0)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  desktopMediaAsset MediaAsset? @relation("BannerDesktopMedia", fields: [desktopMediaAssetId], references: [id], onDelete: SetNull)
  tabletMediaAsset MediaAsset? @relation("BannerTabletMedia", fields: [tabletMediaAssetId], references: [id], onDelete: SetNull)
  mobileMediaAsset MediaAsset? @relation("BannerMobileMedia", fields: [mobileMediaAssetId], references: [id], onDelete: SetNull)
  auditLogs    AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([published, sortOrder])
  @@index([activeAt, expiresAt])
}

model MediaFolder {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  kind      MediaFolderKind
  parentId  String?
  path      String          @unique
  assets    MediaAsset[]
  parent    MediaFolder?    @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  MediaFolder[]   @relation("MediaFolderTree")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([kind])
  @@index([parentId])
}

model MediaAsset {
  id              String                @id @default(cuid())
  publicId        String                @unique
  secureUrl       String
  thumbnailUrl    String
  originalFilename String
  width           Int
  height          Int
  aspectRatio     Decimal               @db.Decimal(10, 4)
  format          String
  fileSize        Int
  dominantColor   String?
  blurHash        String?
  folderId        String
  uploadedById    String?
  deletedAt       DateTime?
  folder          MediaFolder           @relation(fields: [folderId], references: [id], onDelete: Restrict)
  uploadedBy      User?                 @relation("MediaUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  tags            MediaTag[]
  transformations MediaTransformation[]
  usages          MediaUsage[]
  audits          MediaAudit[]
  productImages   ProductImage[]        @relation("ProductImageMedia")
  categoryImages  Category[]            @relation("CategoryImageMedia")
  collectionImages Collection[]          @relation("CollectionImageMedia")
  bannerDesktopImages FeaturedBanner[]  @relation("BannerDesktopMedia")
  bannerTabletImages FeaturedBanner[]   @relation("BannerTabletMedia")
  bannerMobileImages FeaturedBanner[]   @relation("BannerMobileMedia")
  userAvatars      User[]               @relation("UserAvatarMedia")
  reviewImages     ReviewImage[]        @relation("ReviewImageMedia")
  promotionBanners PromotionBanner[]    @relation("PromotionBannerMedia")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([folderId])
  @@index([uploadedById])
  @@index([format])
  @@index([deletedAt])
  @@index([createdAt])
}

model MediaTag {
  id        String      @id @default(cuid())
  assetId   String
  name      String
  slug      String
  asset     MediaAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([assetId, slug])
  @@index([slug])
}

model MediaTransformation {
  id        String      @id @default(cuid())
  assetId   String
  name      String
  width     Int?
  height    Int?
  format    String?
  quality   String?
  url       String
  asset     MediaAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([assetId, name])
  @@index([assetId])
}

model MediaUsage {
  id          String         @id @default(cuid())
  assetId     String
  usageType   MediaUsageType
  entityType  String
  entityId    String
  fieldName   String
  asset       MediaAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([assetId, usageType, entityType, entityId, fieldName])
  @@index([entityType, entityId])
}

model MediaAudit {
  id        String           @id @default(cuid())
  assetId   String?
  actorId   String?
  action    MediaAuditAction
  message   String
  metadata  Json?
  asset     MediaAsset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)
  actor     User?            @relation("MediaAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())

  @@index([assetId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model FitProfile {
  id                   String                 @id @default(cuid())
  userId               String
  measurementProfileId String
  name                 String
  bodyType             BodyType?
  skinTone             SkinTone?
  preferredFit         PreferredFit           @default(REGULAR)
  preferredSleeve      String?
  preferredLength      String?
  preferredNeckStyle   String?
  preferredSilhouette  String?
  comfortPreference    Int                    @default(3)
  maintenancePreference Int                   @default(3)
  isDefault            Boolean                @default(false)
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  measurementProfile   MeasurementProfile     @relation(fields: [measurementProfileId], references: [id], onDelete: Cascade)
  stylePreference      StylePreference?
  colorPreferences     ColorPreference[]
  fabricPreferences    FabricPreference[]
  occasionPreferences  OccasionPreference[]
  recommendations      FitRecommendation[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@unique([userId, measurementProfileId])
  @@index([userId])
  @@index([userId, isDefault])
}

model StylePreference {
  id                  String       @id @default(cuid())
  fitProfileId        String       @unique
  preferredFit        PreferredFit @default(REGULAR)
  sleeveStyle         String?
  garmentLength       String?
  neckStyle           String?
  silhouette          String?
  weatherPreference   String?
  comfortLevel        Int          @default(3)
  maintenanceLevel    Int          @default(3)
  fitProfile          FitProfile   @relation(fields: [fitProfileId], references: [id], onDelete: Cascade)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model ColorPreference {
  id           String     @id @default(cuid())
  fitProfileId String
  colorName    String
  hexCode      String?
  priority     Int        @default(1)
  avoid        Boolean    @default(false)
  fitProfile   FitProfile @relation(fields: [fitProfileId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([fitProfileId, colorName])
  @@index([fitProfileId, priority])
}

model FabricPreference {
  id           String     @id @default(cuid())
  fitProfileId String
  fabricName   String
  priority     Int        @default(1)
  avoid        Boolean    @default(false)
  fitProfile   FitProfile @relation(fields: [fitProfileId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([fitProfileId, fabricName])
  @@index([fitProfileId, priority])
}

model OccasionPreference {
  id           String     @id @default(cuid())
  fitProfileId String
  occasionName String
  priority     Int        @default(1)
  fitProfile   FitProfile @relation(fields: [fitProfileId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([fitProfileId, occasionName])
  @@index([fitProfileId, priority])
}

model FitRule {
  id          String      @id @default(cuid())
  name        String
  code        String      @unique
  type        FitRuleType
  description String?
  conditions  Json
  outcomes    Json
  priority    Int         @default(100)
  weight      Int         @default(10)
